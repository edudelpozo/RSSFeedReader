@page "/"
@using RSSFeedReader.UI.Services
@inject ISubscriptionApiClient ApiClient

<h1>RSS Feed Subscriptions</h1>

<div class="mb-3">
    <label for="feedUrl" class="form-label">Feed URL</label>
    <div class="input-group">
        <input id="feedUrl"
               type="text"
               class="form-control"
               placeholder="https://example.com/feed"
               @bind="newUrl"
               @bind:event="oninput" />
        <button class="btn btn-primary"
                @onclick="AddSubscriptionAsync"
                disabled="@isLoading">
            @(isLoading ? "Adding…" : "Add")
        </button>
    </div>
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="text-danger mt-1">@errorMessage</div>
    }
</div>

<h2>Subscriptions</h2>

@if (subscriptions.Count == 0)
{
    <p class="text-muted">No subscriptions yet.</p>
}
else
{
    <ul class="list-group">
        @foreach (var sub in subscriptions)
        {
            <li class="list-group-item">@sub.Url</li>
        }
    </ul>
}

@code {
    private string newUrl = string.Empty;
    private List<SubscriptionDto> subscriptions = [];
    private string errorMessage = string.Empty;
    private bool isLoading;

    private async Task AddSubscriptionAsync()
    {
        if (string.IsNullOrWhiteSpace(newUrl))
        {
            errorMessage = "Please enter a feed URL.";
            return;
        }

        isLoading = true;
        errorMessage = string.Empty;

        var result = await ApiClient.AddSubscriptionAsync(newUrl);

        if (result is not null)
        {
            subscriptions.Add(result);
            newUrl = string.Empty;
        }
        else
        {
            errorMessage = "Failed to add subscription. Please try again.";
        }

        isLoading = false;
    }
}
